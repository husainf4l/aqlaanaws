@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password reset";
}

<div class="text-center py-5">
    <h2 class="ds-title mb-2">Password reset</h2>
    <p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">Your password has been reset. You can now log in.</p>
    <a asp-page="./Login" class="ds-btn ds-btn-primary">Log in</a>
</div>
