@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="ds-title mb-2">Forgot password</h2>
        <p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">Enter your email and we'll send reset instructions (if email is configured).</p>

        <form method="post" class="ds-card p-4">
            <div asp-validation-summary="ModelOnly" class="ds-alert ds-alert-destructive mb-3"></div>
            <div class="mb-4">
                <label asp-for="Input.Email" class="form-label ds-caption d-block mb-1">Email</label>
                <input asp-for="Input.Email" class="form-control ds-input" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="ds-btn ds-btn-primary">Submit</button>
        </form>

        <p class="mt-3 ds-body" style="color: var(--ds-muted-foreground);">
            <a class="ds-link" asp-page="./Login">Back to login</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
