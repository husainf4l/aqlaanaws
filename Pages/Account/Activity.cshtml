@page
@model AqlaAwsS3Manager.Pages.Account.ActivityModel
@{
    ViewData["Title"] = "Activity";
}

<h2 class="ds-title mb-2">Activity log</h2>
<p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">Recent actions across the app.</p>

<div class="ds-card overflow-hidden">
    <table class="ds-table mb-0">
        <thead>
            <tr>
                <th>Time (UTC)</th>
                <th>Action</th>
                <th>Resource</th>
                <th>User</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Entries)
            {
                <tr>
                    <td class="ds-cell-muted ds-tabular">@e.At.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@e.Action</td>
                    <td>@(e.ResourceType != null ? $"{e.ResourceType}: {e.ResourceKey}" : "—")</td>
                    <td class="ds-cell-muted">@e.UserId</td>
                    <td class="ds-cell-muted">@(e.IpAddress ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
    @if (Model.Entries.Count == 0)
    {
        <div class="ds-empty">
            <p class="ds-empty-title mb-0">No activity yet</p>
        </div>
    }
</div>

@if (Model.TotalCount > Model.PageSize)
{
    <nav class="mt-3 d-flex justify-content-between align-items-center">
        <span class="ds-body" style="color: var(--ds-muted-foreground);">Page @Model.PageNumber of @((Model.TotalCount + Model.PageSize - 1) / Model.PageSize)</span>
        <div class="d-flex gap-2">
            @if (Model.PageNumber > 1)
            {
                <a class="ds-btn ds-btn-outline ds-btn-sm" asp-page="./Activity" asp-route-p="@(Model.PageNumber - 1)">Previous</a>
            }
            @if (Model.PageNumber * Model.PageSize < Model.TotalCount)
            {
                <a class="ds-btn ds-btn-outline ds-btn-sm" asp-page="./Activity" asp-route-p="@(Model.PageNumber + 1)">Next</a>
            }
        </div>
    </nav>
}
