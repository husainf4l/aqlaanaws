@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="ds-title mb-2">Reset password</h2>
        <p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">Enter your new password below.</p>

        <form method="post" class="ds-card p-4">
            <div asp-validation-summary="ModelOnly" class="ds-alert ds-alert-destructive mb-3"></div>
            <input type="hidden" asp-for="Code" />
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label ds-caption d-block mb-1"></label>
                <input asp-for="Input.Email" class="form-control ds-input" readonly />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label ds-caption d-block mb-1"></label>
                <input asp-for="Input.Password" class="form-control ds-input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label ds-caption d-block mb-1"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control ds-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="ds-btn ds-btn-primary">Reset password</button>
        </form>

        <p class="mt-3">
            <a class="ds-link" asp-page="./Login">Back to login</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
