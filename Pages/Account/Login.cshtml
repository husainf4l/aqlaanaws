@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="ds-title mb-2">Log in</h2>
        <p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">Sign in to access S3 Storage Manager.</p>

        <form method="post" class="ds-card p-4">
            <div asp-validation-summary="ModelOnly" class="ds-alert ds-alert-destructive mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label ds-caption d-block mb-1"></label>
                <input asp-for="Input.Email" class="form-control ds-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label ds-caption d-block mb-1"></label>
                <input asp-for="Input.Password" class="form-control ds-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label ds-body"></label>
            </div>

            <input type="hidden" asp-for="ReturnUrl" />

            <div class="d-flex gap-2">
                <button type="submit" class="ds-btn ds-btn-primary">Log in</button>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="ds-btn ds-btn-outline">Register</a>
            </div>
        </form>

        <p class="mt-3 ds-body" style="color: var(--ds-muted-foreground);">
            <a class="ds-link" asp-page="./ForgotPassword">Forgot your password?</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
