@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="text-center py-5">
    <h2 class="ds-title mb-2">Check your email</h2>
    <p class="ds-body mb-4" style="color: var(--ds-muted-foreground);">If an account exists for that email, we've sent password reset instructions (when email is configured).</p>
    <a asp-page="./Login" class="ds-btn ds-btn-primary">Back to login</a>
</div>
